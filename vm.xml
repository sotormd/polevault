<domain type="kvm">
  <name>polevault</name>

  <memory unit="MiB">1024</memory>
  <vcpu>1</vcpu>

  <memoryBacking>
    <source type="memfd"/>
    <access mode="shared"/>
  </memoryBacking>

  <os firmware="efi">
    <type arch="x86_64" machine="q35">hvm</type>

    <firmware>
      <feature enabled="no" name="enrolled-keys"/>
      <feature enabled="yes" name="secure-boot"/>
    </firmware>

    <loader
      readonly="yes"
      secure="yes"
      type="pflash"
      format="raw">/run/libvirt/nix-ovmf/edk2-x86_64-secure-code.fd</loader>

    <nvram
      template="/run/libvirt/nix-ovmf/edk2-i386-vars.fd"
      templateFormat="raw"
      format="raw">/var/lib/libvirt/qemu/nvram/polevault_VARS.fd</nvram>

    <boot dev="hd"/>
  </os>

  <features>
    <acpi/>
    <apic/>
    <smm state="on"/>
  </features>

  <cpu mode="host-passthrough" check="none"/>

  <devices>
    <emulator>/run/libvirt/nix-emulators/qemu-system-x86_64</emulator>

    <disk type="file" device="disk">
      <driver name="qemu" type="raw" discard="unmap"/>
      <source file="/var/lib/libvirt/images/polevault_vm.raw"/>
      <target dev="sda" bus="sata"/>
    </disk>
    
    <serial type="pty">
      <target type="isa-serial" port="0"/>
    </serial>

    <console type="pty">
      <target type="serial" port="0"/>
    </console>

    <tpm model="tpm-crb">
      <backend type="emulator" version="2.0"/>
    </tpm>

    <rng model="virtio">
      <backend model="random">/dev/urandom</backend>
    </rng>

    <watchdog model="itco" action="reset"/>

    <memballoon model="virtio"/>

    <filesystem type="mount" accessmode="passthrough">
      <driver type="virtiofs"/>
      <source dir="/persist/polevault/vault"/>
      <target dir="vaultwarden-data"/>
    </filesystem>

    <interface type="network">
      <mac address="52:54:00:23:80:48"/>
      <source network="polevault"/>
      <model type="virtio"/>
    </interface>

  </devices>
</domain>
